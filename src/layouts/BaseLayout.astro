---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Portfolio",
  description = "フリーランスエンジニアのポートフォリオサイト。制作実績・スキル・お問い合わせはこちら。",
} = Astro.props;

const nav = [
  { href: "/", label: "Home" },
  { href: "/about/", label: "About" },
  { href: "/works/", label: "Works" },
  { href: "/skills/", label: "Skills" },
  { href: "/blog/", label: "Blog" },
  { href: "/contact/", label: "Contact" },
];

const current = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo"><span class="logo-prompt">~/</span>portfolio</a>
        <nav>
          <ul class="nav-list">
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      "nav-link",
                      {
                        active:
                          item.href === "/"
                            ? current === "/"
                            : current.startsWith(item.href),
                      },
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p class="footer-logo"><span class="logo-prompt">~/</span>portfolio</p>
        <p class="footer-copy">
          &copy; {new Date().getFullYear()} portfolio. All rights reserved.
        </p>
      </div>
    </footer>

    <script>
      // スクロールに合わせて .reveal 要素をふわっと表示する
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12 },
      );
      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 14, 26, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--c-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
  }

  .logo,
  .footer-logo {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    color: var(--c-text);
  }

  .logo-prompt {
    color: var(--c-primary);
  }

  .nav-list {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: var(--c-text-soft);
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.88rem;
    padding-bottom: 0.2rem;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--c-primary);
    border-bottom-color: var(--c-primary);
  }

  .site-footer {
    margin-top: 4rem;
    padding: 2.5rem 0;
    text-align: center;
    background: linear-gradient(
      to right,
      rgba(0, 229, 255, 0.05),
      rgba(139, 92, 246, 0.07),
      rgba(255, 45, 149, 0.05)
    );
    border-top: 1px solid var(--c-border);
  }

  .footer-logo {
    margin: 0;
  }

  .footer-copy {
    color: var(--c-text-soft);
    font-size: 0.85rem;
    margin: 0.4rem 0 0;
  }

  @media (max-width: 720px) {
    .header-inner {
      flex-direction: column;
      gap: 0.5rem;
    }

    .nav-list {
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
