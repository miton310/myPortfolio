---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const categories = ["技術記事", "学習ログ", "運用メモ"] as const;

const formatDate = (date: Date) =>
  date.toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<BaseLayout title="Blog | Portfolio" description="技術記事・学習ログ・運用メモを書いています。">
  <section class="section">
    <div class="container blog-container">
      <h1 class="section-title">Blog / Notes</h1>
      <p class="section-sub">技術記事・学習ログ・運用メモ</p>

      <div class="filter" role="group" aria-label="カテゴリで絞り込み">
        <button class="filter-btn active" data-category="all">すべて</button>
        {
          categories.map((category) => (
            <button class="filter-btn" data-category={category}>
              {category}
            </button>
          ))
        }
      </div>

      <ul class="post-list">
        {
          posts.map((post) => (
            <li class="post-item" data-category={post.data.category}>
              <a href={`/blog/${post.id}/`} class="card post-card">
                <div class="post-meta">
                  <span class="post-cat">{post.data.category}</span>
                  <span class="post-date">{formatDate(post.data.date)}</span>
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-tags">
                  {post.data.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLElement>(".post-item");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      buttons.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      const category = btn.dataset.category;
      items.forEach((item) => {
        const show = category === "all" || item.dataset.category === category;
        item.style.display = show ? "" : "none";
      });
    });
  });
</script>

<style>
  .blog-container {
    max-width: 760px;
  }

  .filter {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 2.2rem;
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--c-text-soft);
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: 6px;
    padding: 0.45rem 1.1rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, box-shadow 0.2s;
  }

  .filter-btn:hover {
    color: var(--c-primary);
    border-color: rgba(0, 229, 255, 0.4);
  }

  .filter-btn.active {
    color: var(--c-primary);
    border-color: var(--c-primary);
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.25);
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.4rem;
  }

  .post-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.5rem 1.8rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.5rem;
  }

  .post-cat {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--c-teal);
    border: 1px solid rgba(0, 255, 157, 0.3);
    border-radius: 4px;
    padding: 0.05rem 0.5rem;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--c-text-soft);
  }

  .post-title {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
  }

  .post-desc {
    margin: 0 0 0.8rem;
    font-size: 0.88rem;
    color: var(--c-text-soft);
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
</style>
