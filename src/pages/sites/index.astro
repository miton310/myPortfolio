---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const sites = (await getCollection("sites")).sort((a, b) => {
  if (a.data.order !== b.data.order) return a.data.order - b.data.order;
  const ad = a.data.since?.valueOf() ?? 0;
  const bd = b.data.since?.valueOf() ?? 0;
  return bd - ad;
});

const formatSince = (date?: Date) =>
  date
    ? date.toLocaleDateString("ja-JP", { year: "numeric", month: "long" }) +
      "〜"
    : null;

const hostOf = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return url;
  }
};
---

<BaseLayout
  title="Sites | Portfolio"
  description="自分で企画・開発・運用しているサイトやサービスの一覧です。"
>
  <section class="section">
    <div class="container sites-container">
      <h1 class="section-title">Sites</h1>
      <p class="section-sub">運用しているサイト・サービス</p>

      <p class="lead">
        制作して終わりではなく、公開後も継続的に運用・改善しているサイトやサービスをまとめています。
        日々の保守やコンテンツ更新、数字を見ながらの改善まで含めて手を動かしているものたちです。
      </p>

      <ul class="site-list">
        {
          sites.map((site) => (
            <li class="card site-card reveal">
              <div class="site-head">
                <div class="site-meta">
                  <span class="site-cat">{site.data.category}</span>
                  <span
                    class:list={[
                      "site-status",
                      {
                        "is-active": site.data.status === "運用中",
                        "is-paused": site.data.status === "公開停止",
                      },
                    ]}
                  >
                    {site.data.status}
                  </span>
                </div>
                {formatSince(site.data.since) && (
                  <span class="site-since">{formatSince(site.data.since)}</span>
                )}
              </div>

              <h2 class="site-title">{site.data.title}</h2>
              <p class="site-desc">{site.data.description}</p>

              <p class="site-role">
                <span class="role-label">担当</span>
                {site.data.role}
              </p>

              <div class="site-tags">
                {site.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>

              <a
                href={site.data.url}
                target="_blank"
                rel="noopener"
                class="site-link"
              >
                {hostOf(site.data.url)} ↗
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .sites-container {
    max-width: 820px;
  }

  .lead {
    color: var(--c-text-soft);
    margin: 0 0 2.4rem;
    font-size: 0.92rem;
  }

  .site-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.4rem;
  }

  .site-card {
    padding: 1.5rem 1.7rem;
    border-left: 3px solid var(--c-secondary);
  }

  .site-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 0.7rem;
  }

  .site-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .site-cat {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--c-secondary);
    border: 1px solid rgba(139, 92, 246, 0.4);
    border-radius: 4px;
    padding: 0.05rem 0.55rem;
  }

  .site-status {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.05rem 0.55rem;
    border-radius: 4px;
    color: var(--c-text-soft);
    border: 1px solid var(--c-border);
  }

  .site-status.is-active {
    color: var(--c-teal);
    border-color: rgba(0, 255, 157, 0.35);
  }

  .site-status.is-active::before {
    content: "● ";
    font-size: 0.6em;
    vertical-align: middle;
  }

  .site-status.is-paused {
    color: var(--c-text-soft);
    opacity: 0.7;
  }

  .site-since {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--c-text-soft);
    white-space: nowrap;
  }

  .site-title {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
  }

  .site-desc {
    margin: 0 0 0.9rem;
    font-size: 0.88rem;
    color: var(--c-text-soft);
    line-height: 1.8;
  }

  .site-role {
    margin: 0 0 0.9rem;
    font-size: 0.83rem;
    color: var(--c-text-soft);
  }

  .role-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--c-text);
    background: var(--c-bg-soft);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    padding: 0.05rem 0.5rem;
    margin-right: 0.6rem;
  }

  .site-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 1.1rem;
  }

  .site-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--c-primary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .site-link:hover {
    border-bottom-color: var(--c-primary);
  }

  @media (max-width: 560px) {
    .site-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }
  }
</style>
