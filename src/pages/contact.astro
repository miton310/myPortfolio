---
import BaseLayout from "../layouts/BaseLayout.astro";

// エックスサーバー上の PHP（public/mail.php）でメールを送信する。
// public/ 配下のファイルはビルド時にサイト直下へコピーされるため /mail.php で動作する。
const FORM_ENDPOINT = "/mail.php";

const EMAIL = "info@dokkoi.jp";
const GITHUB_URL = "https://github.com/miton310";
const X_URL = "https://x.com/UptownGirlsBand";
const QIITA_URL = "https://qiita.com/miton";
---

<BaseLayout title="Contact | Portfolio" description="お仕事のご依頼・ご相談はこちらから。">
  <section class="section">
    <div class="container contact-container">
      <h1 class="section-title">Contact</h1>
      <p class="section-sub">お仕事のご依頼・ご相談はこちらから</p>

      <div class="channels">
        <a href={`mailto:${EMAIL}`} class="card channel">
          <p class="channel-label">Email</p>
          <p class="channel-value">{EMAIL}</p>
          <p class="channel-note">メールでのご連絡はこちら</p>
        </a>
        <a
          href={GITHUB_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="card channel"
        >
          <p class="channel-label">GitHub</p>
          <p class="channel-value">{GITHUB_URL.replace("https://", "")}</p>
          <p class="channel-note">コードや活動状況はこちら</p>
        </a>
        <a
          href={X_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="card channel"
        >
          <p class="channel-label">X</p>
          <p class="channel-value">@{X_URL.split("/").pop()}</p>
          <p class="channel-note">日々の発信はこちら</p>
        </a>
        <a
          href={QIITA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="card channel"
        >
          <p class="channel-label">Qiita</p>
          <p class="channel-value">{QIITA_URL.replace("https://", "")}</p>
          <p class="channel-note">技術記事はこちら</p>
        </a>
      </div>

      <div class="card contact-card">
        <h2 class="form-title">お問い合わせフォーム</h2>
        <form action={FORM_ENDPOINT} method="POST" class="contact-form">
          <label class="field">
            <span class="field-label">お名前 <em>必須</em></span>
            <input type="text" name="name" required placeholder="山田 太郎" />
          </label>
          <label class="field">
            <span class="field-label">メールアドレス <em>必須</em></span>
            <input
              type="email"
              name="email"
              required
              placeholder="example@example.com"
            />
          </label>
          <label class="field">
            <span class="field-label">ご相談内容 <em>必須</em></span>
            <textarea
              name="message"
              rows="6"
              required
              placeholder="ご依頼内容、ご予算、希望納期などをお書きください"></textarea>
          </label>
          {/* スパム対策のハニーポット（人間には見えない・入力されたらボット扱い） */}
          <div class="hp" aria-hidden="true">
            <label>
              Webサイト
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </label>
          </div>
          <p class="form-status" role="status" aria-live="polite"></p>
          <button type="submit" class="btn btn-primary">送信する</button>
        </form>
      </div>

      <p class="contact-note">通常 2 営業日以内にご返信します。</p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>(".contact-form");
  const statusEl = document.querySelector<HTMLParagraphElement>(".form-status");

  if (form && statusEl) {
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      statusEl.textContent = "";
      statusEl.className = "form-status";
      if (button) {
        button.disabled = true;
        button.textContent = "送信中…";
      }

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { "X-Requested-With": "XMLHttpRequest" },
        });
        const data = await response
          .json()
          .catch(() => ({ ok: response.ok, message: "" }));

        if (response.ok && data.ok) {
          form.reset();
          statusEl.textContent =
            data.message || "お問い合わせを送信しました。ありがとうございます。";
          statusEl.classList.add("is-success");
        } else {
          statusEl.textContent =
            data.message ||
            "送信に失敗しました。お手数ですが時間をおいて再度お試しください。";
          statusEl.classList.add("is-error");
        }
      } catch {
        statusEl.textContent =
          "通信エラーが発生しました。メールでのご連絡もご検討ください。";
        statusEl.classList.add("is-error");
      } finally {
        if (button) {
          button.disabled = false;
          button.textContent = "送信する";
        }
      }
    });
  }
</script>

<style>
  .contact-container {
    max-width: 640px;
  }

  .channels {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
    margin-bottom: 1.8rem;
  }

  .channel {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.3rem 1.5rem;
  }

  .channel-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--c-primary);
    margin: 0 0 0.3rem;
  }

  .channel-label::before {
    content: "// ";
    color: var(--c-text-soft);
  }

  .channel-value {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    font-weight: 700;
    margin: 0 0 0.3rem;
    word-break: break-all;
  }

  .channel-note {
    font-size: 0.8rem;
    color: var(--c-text-soft);
    margin: 0;
  }

  .contact-card {
    padding: 2.2rem;
  }

  .form-title {
    margin: 0 0 1.4rem;
    font-size: 1.15rem;
  }

  .contact-form {
    display: grid;
    gap: 1.4rem;
  }

  .field {
    display: grid;
    gap: 0.4rem;
  }

  .field-label {
    font-weight: 700;
    font-size: 0.92rem;
  }

  .field-label em {
    font-style: normal;
    font-size: 0.72rem;
    color: #060914;
    background: var(--c-accent);
    border-radius: 4px;
    padding: 0.08rem 0.55rem;
    margin-left: 0.4rem;
    vertical-align: middle;
  }

  input,
  textarea {
    font: inherit;
    color: var(--c-text);
    padding: 0.75rem 1rem;
    border: 1px solid var(--c-border);
    border-radius: 8px;
    background: var(--c-bg-soft);
    transition: border-color 0.2s, box-shadow 0.2s;
    resize: vertical;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--c-text-soft);
    opacity: 0.6;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--c-primary);
    box-shadow: 0 0 12px rgba(0, 229, 255, 0.2);
  }

  button.btn {
    border: none;
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    justify-self: start;
  }

  button.btn:disabled {
    opacity: 0.6;
    cursor: progress;
  }

  /* ハニーポット（画面外に隠す） */
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  /* 送信結果メッセージ */
  .form-status {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.7;
  }

  .form-status:empty {
    display: none;
  }

  .form-status.is-success {
    color: var(--c-teal);
  }

  .form-status.is-error {
    color: var(--c-accent);
  }

  .contact-note {
    margin-top: 1.6rem;
    font-size: 0.85rem;
    color: var(--c-text-soft);
    text-align: center;
  }

  @media (max-width: 560px) {
    .channels {
      grid-template-columns: 1fr;
    }
  }
</style>
