---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";

const works = (await getCollection("works", ({ data }) => data.featured))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const strengths = [
  {
    no: "01",
    title: "一気通貫の対応力",
    body: "要件整理・設計からデザイン・実装・公開後の運用まで、窓口ひとつでお任せいただけます。分業によるコミュニケーションロスがありません。",
  },
  {
    no: "02",
    title: "成果から逆算した実装",
    body: "「作って終わり」にせず、表示速度・SEO・コンバージョンといった数字に効く部分を優先して設計します。",
  },
  {
    no: "03",
    title: "わかりやすいコミュニケーション",
    body: "専門用語をかみくだいた説明と、こまめな進捗共有を徹底。非エンジニアの方ともスムーズに進められます。",
  },
];

const stackSummary = [
  { category: "フロントエンド", items: ["HTML/CSS", "TypeScript", "React", "Next.js", "Nuxt", "Astro"] },
  { category: "バックエンド", items: ["Node.js", "Ruby on Rails", "PHP/Laravel", "Python", "REST API"] },
  { category: "CMS / EC", items: ["WordPress", "microCMS", "Shopify"] },
  { category: "インフラ", items: ["AWS", "さくらVPS", "Vercel", "Docker", "GitHub Actions"] },
  { category: "自動化 / DB", items: ["GAS", "Bash", "Gulp", "PostgreSQL", "MySQL", "Firebase"] },
];
---

<BaseLayout title="miton310's Portfolio">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="terminal">
        <div class="terminal-bar">
          <span class="dot"></span><span class="dot"></span><span class="dot"
          ></span>
          <p class="terminal-name">portfolio — zsh</p>
        </div>
        <div class="terminal-body">
          <p class="line" data-type="cmd">
            <span class="prompt">$</span> <span class="ln-text">whoami</span>
          </p>
          <p class="line" data-type="out">
            <span class="ln-text output">freelance-engineer</span>
          </p>
          <p class="line" data-type="cmd">
            <span class="prompt">$</span> <span class="ln-text">cat stack.txt</span>
          </p>
          <p class="line" data-type="out">
            <span class="ln-text output">react / next / astro / rails / laravel / aws</span>
          </p>
          <p class="line" data-type="cmd">
            <span class="prompt">$</span> <span class="ln-text">cat services.txt</span>
          </p>
          <p class="line" data-type="out">
            <span class="ln-text output">web-site / web-app / cms-ec / automation</span>
          </p>
          <p class="line" data-type="prompt">
            <span class="prompt">$</span> <span class="cursor">█</span>
          </p>
        </div>
      </div>
      <div class="hero-actions">
        <a href="/works/" class="btn btn-primary">制作実績を見る</a>
        <a href="/contact/" class="btn btn-outline">お問い合わせ</a>
      </div>
    </div>
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </section>

  <!-- Featured Works -->
  {
    works.length > 0 && (
      <section class="section section-tint">
        <div class="container reveal">
          <h2 class="section-title">Featured Works</h2>
          <p class="section-sub">最近の制作実績</p>
          <div class="works-grid">
            {works.map((work) => (
              <WorkCard work={work} />
            ))}
          </div>
          <p class="works-more">
            <a href="/works/" class="btn btn-outline">
              すべての実績を見る
            </a>
          </p>
        </div>
      </section>
    )
  }

  <!-- Strengths -->
  <section class="section">
    <div class="container reveal">
      <h2 class="section-title">Strengths</h2>
      <p class="section-sub">選ばれる理由</p>
      <div class="strengths-grid">
        {
          strengths.map((item) => (
            <div class="card strength-card">
              <p class="strength-no">{item.no}</p>
              <h3 class="strength-title">{item.title}</h3>
              <p class="strength-body">{item.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Tech Stack Summary -->
  <section class="section section-tint">
    <div class="container reveal">
      <h2 class="section-title">Tech Stack</h2>
      <p class="section-sub">主な使用技術</p>
      <dl class="stack-list">
        {
          stackSummary.map((group) => (
            <div class="stack-row">
              <dt class="stack-cat">{group.category}</dt>
              <dd class="stack-items">
                {group.items.map((item) => (
                  <span class="tag">{item}</span>
                ))}
              </dd>
            </div>
          ))
        }
      </dl>
      <p class="stack-more">
        <a href="/skills/">スキルの詳細を見る →</a>
      </p>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section">
    <div class="container reveal">
      <div class="cta card">
        <h2 class="cta-title">お仕事のご相談を受け付けています</h2>
        <p class="cta-text">
          「こんなことってできますか?」くらいの、ふわっとした段階のご相談も大歓迎です。お気軽にどうぞ。
        </p>
        <a href="/contact/" class="btn btn-primary">お問い合わせはこちら</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // ヒーローのターミナルを1行ずつ打って表示する演出。
  // prefers-reduced-motion 時は何もせず、サーバー出力の静止状態のまま見せる。
  const body = document.querySelector<HTMLElement>(".terminal-body");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (body && !reduce) {
    const lines = Array.from(body.querySelectorAll<HTMLElement>(".line"));
    const restCursor = body.querySelector<HTMLElement>(".cursor");

    // 全行の領域を確保したまま隠す（box が伸び縮みしないように）。
    body.classList.add("is-animating");
    if (restCursor) restCursor.style.visibility = "hidden";

    const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));

    const typeText = (el: HTMLElement, text: string) =>
      new Promise<void>((resolve) => {
        let i = 0;
        const tick = () => {
          el.textContent = text.slice(0, i);
          if (i++ < text.length) setTimeout(tick, 55);
          else resolve();
        };
        tick();
      });

    const run = async () => {
      for (const line of lines) {
        const type = line.dataset.type;

        if (type === "prompt") {
          line.classList.add("is-shown");
          if (restCursor) restCursor.style.visibility = "";
          break;
        }

        const textEl = line.querySelector<HTMLElement>(".ln-text");
        if (!textEl) continue;
        const full = (textEl.textContent ?? "").trim();
        line.classList.add("is-shown");

        if (type === "cmd") {
          textEl.textContent = "";
          line.classList.add("is-typing");
          await typeText(textEl, full);
          line.classList.remove("is-typing");
          await wait(180);
        } else {
          await wait(220);
        }
      }
    };

    // 表示直後の唐突さを避けて少し置いてから開始。
    wait(350).then(run);
  }
</script>

<style>
  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 0 5rem;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.4rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ターミナル風ウィンドウ */
  .terminal {
    width: min(560px, 100%);
    background: #0c1120;
    border: 1px solid var(--c-border);
    border-radius: 10px;
    box-shadow: var(--shadow);
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0.9rem;
    border-bottom: 1px solid var(--c-border);
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--c-border);
  }

  .dot:nth-child(1) {
    background: #ff5f57;
  }

  .dot:nth-child(2) {
    background: #febc2e;
  }

  .dot:nth-child(3) {
    background: #28c840;
  }

  .terminal-name {
    margin: 0 auto;
    color: var(--c-text-soft);
    font-size: 0.75rem;
  }

  .terminal-body {
    padding: 1.1rem 1.2rem 1.3rem;
    line-height: 2;
  }

  .terminal-body p {
    margin: 0;
  }

  .prompt {
    color: var(--c-teal);
  }

  .output {
    color: var(--c-text-soft);
  }

  .cursor {
    color: var(--c-primary);
    animation: blink 1.1s step-end infinite;
  }

  /* タイピング演出：行の領域は確保したまま、表示済みの行だけ見せる */
  .terminal-body.is-animating .line {
    visibility: hidden;
  }

  .terminal-body.is-animating .line.is-shown {
    visibility: visible;
  }

  /* 打鍵中の行の末尾に出るカーソル */
  .line.is-typing .ln-text::after {
    content: "▋";
    margin-left: 1px;
    color: var(--c-primary);
    animation: blink 1.1s step-end infinite;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.16;
    pointer-events: none;
    animation: float 16s ease-in-out infinite;
  }

  .glow-1 {
    width: 380px;
    height: 380px;
    background: var(--c-secondary);
    top: -140px;
    right: -100px;
  }

  .glow-2 {
    width: 300px;
    height: 300px;
    background: var(--c-primary);
    bottom: -120px;
    left: -80px;
    animation-delay: -7s;
  }

  /* Featured Works */
  .section-tint {
    background: linear-gradient(
      to bottom right,
      rgba(0, 229, 255, 0.04),
      rgba(139, 92, 246, 0.07)
    );
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.6rem;
  }

  .works-more {
    text-align: center;
    margin: 2.6rem 0 0;
  }

  /* Strengths */
  .strengths-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.6rem;
  }

  .strength-card {
    padding: 1.6rem 1.7rem;
  }

  .strength-no {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--c-primary);
    margin: 0 0 0.6rem;
  }

  .strength-no::before {
    content: "// ";
    color: var(--c-text-soft);
  }

  .strength-title {
    margin: 0 0 0.6rem;
    font-size: 1.1rem;
  }

  .strength-body {
    margin: 0;
    font-size: 0.88rem;
    color: var(--c-text-soft);
    line-height: 1.8;
  }

  /* Tech Stack Summary */
  .stack-list {
    margin: 0;
    display: grid;
    gap: 0.4rem;
  }

  .stack-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1rem;
    align-items: center;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--c-border);
    border-radius: 10px;
    background: var(--c-card);
  }

  .stack-cat {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--c-text);
    font-weight: 700;
  }

  .stack-items {
    margin: 0;
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .stack-more {
    margin: 1.6rem 0 0;
    text-align: right;
    font-size: 0.9rem;
  }

  /* CTA */
  .cta {
    text-align: center;
    padding: 3.2rem 2rem;
  }

  .cta-title {
    font-size: clamp(1.4rem, 3.5vw, 1.8rem);
    margin: 0 0 0.8rem;
  }

  .cta-text {
    color: var(--c-text-soft);
    margin: 0 0 1.8rem;
  }

  @media (max-width: 860px) {
    .works-grid,
    .strengths-grid {
      grid-template-columns: 1fr;
    }

    .stack-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
